      Fn::If:
      - StackNameIsWalletDocBuilderFE
      - Fn::FindInMap:
        - EnvironmentVariables
        - Ref: Environment
        - SelfUrl
      - Fn::Sub:
        - ${AWS::StackName}-${SelfUrl}
        - SelfUrl:
            Fn::FindInMap:
            - EnvironmentVariables
            - Ref: Environment
            - SelfUrl
